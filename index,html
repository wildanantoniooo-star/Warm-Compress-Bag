            if(price) document.getElementById('display-price').innerText = 'Rp ' + Number(price).toLocaleString('id-ID');
            
            if (image) {
                const mainImg = document.getElementById('main-product-img');
                if (mainImg) {
                    mainImg.src = image;
                    const targetIndex = 0;
                    if (mainSwiper) mainSwiper.slideTo(targetIndex);
                }
            }

            const summary = document.getElementById('variant-summary');
            if (summary) {
