        function toggleDropdown(el) { el.classList.toggle('active'); el.nextElementSibling.classList.toggle('active'); }
        function scrollToOrder() { 
          const target = document.getElementById('order-section');
          if (target) target.scrollIntoView({ behavior: 'smooth' }); 
        }
        function openLightbox(src) { 
          const img = document.getElementById('lightbox-img');
          if (img) img.src = src; 
          const lb = document.getElementById('lightbox');
          if (lb) lb.style.display = 'flex'; 
        }
        
        function updateShippingDate() {
            const months = ["Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Agt", "Sep", "Okt", "Nov", "Des"];
            const today = new Date();
            const start = new Date(today);
            start.setDate(today.getDate() + 3);
            const end = new Date(today);
            end.setDate(today.getDate() + 6);
            
            let dateStr = "";
            if (start.getMonth() === end.getMonth()) {
                dateStr = start.getDate() + " - " + end.getDate() + " " + months[start.getMonth()];
            } else {
                dateStr = start.getDate() + " " + months[start.getMonth()] + " - " + end.getDate() + " " + months[end.getMonth()];
            }
            
            const el = document.getElementById('dynamic-shipping-date');
            if (el) el.innerText = "Garansi Tiba: " + dateStr;
        }

        function updateReviewDates() {
            const els = document.querySelectorAll('.dynamic-date');
            els.forEach(el => {
                const daysAgo = parseInt(el.getAttribute('data-days-ago')) || 0;
                const date = new Date();
                date.setDate(date.getDate() - daysAgo);
                
                const day = String(date.getDate()).padStart(2, '0');
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const year = date.getFullYear();
                
                el.innerText = day + '/' + month + '/' + year;
            });
        }

        function startTimer(duration, display) {
            let timer = duration, hours, minutes, seconds;
            setInterval(function () {
                hours = Math.floor(timer / 3600);
                minutes = Math.floor((timer % 3600) / 60);
                seconds = Math.floor(timer % 60);

                const hDisplay = hours < 10 ? "0" + hours : hours;
                const mDisplay = minutes < 10 ? "0" + minutes : minutes;
                const sDisplay = seconds < 10 ? "0" + seconds : seconds;

                if (display) display.textContent = hDisplay + " : " + mDisplay + " : " + sDisplay;

                if (--timer < 0) {
                    timer = duration;
                }
            }, 1000);
        }

        window.addEventListener('DOMContentLoaded', () => {
            updateShippingDate();
            updateReviewDates();
            
            const firstVariant = document.querySelector('.variant-card');
            if(firstVariant) (firstVariant).click();

            const timerDisplay = document.querySelector('#timer');
            if(timerDisplay) {
                const durationHours = 1;
                startTimer(3600 * durationHours, timerDisplay);
            }

            if (document.querySelector('.related-swiper')) {
                new Swiper('.related-swiper', {
                    slidesPerView: 'auto',
                    spaceBetween: 15,
                    freeMode: true,
                    autoplay: { delay: 3000, disableOnInteraction: false },
                });
            }
        });
    </script>

