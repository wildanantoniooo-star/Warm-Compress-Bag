            'hesti': true, 'ika': true, 'kiki': true, 'mega': true, 'putri': true, 'ratna': true, 'utami': true, 'dewi': true, 'sri': true, 
            'bella': true, 'nisa': true, 'rina': true, 'sari': true, 'wati': true, 'santi': true, 'kartika': true, 'amalia': true, 
            'lia': true, 'ria': true, 'dhea': true, 'aulia': true, 'ayu': true, 'intan': true, 'angel': true, 'chandra': true, 
            'cantika': true, 'lisa': true, 'novi': true, 'sarah': true, 'mey': true, 'meylani': true, 'selvi': true, 'selvia': true, 
            'linda': true, 'yani': true, 'ani': true, 'erika': true, 'elizabeth': true, 'rachel': true, 'clara': true, 'nadia': true, 
            'nadya': true, 'fani': true, 'fanny': true, 'tari': true, 'ndah': true, 'nia': true, 'grace': true, 'sherly': true,
            'shinta': true, 'marta': true, 'maria': true, 'keisha': true, 'aurora': true, 'nayla': true, 'zahra': true,
            'aisyah': true, 'khadijah': true, 'fatimah': true, 'salma': true, 'maharani': true, 'puji': true, 'asri': true, 
            'nurul': true, 'safira': true, 'keyla': true, 'chika': true
          };

          var words = lower.split(/s+/);
          for (var i = 0; i < words.length; i++) {
            if (femaleSet[words[i]]) return true;
          }

          var femaleTriggers = [
            'siti', 'amanda', 'indah', 'jessica', 'syifa', 'anisa', 'dian', 'fitri', 
            'hesti', 'ika', 'kiki', 'mega', 'putri', 'ratna', 'utami', 'dewi', 'sri', 
            'bella', 'nisa', 'rina', 'sari', 'wati', 'santi', 'kartika', 'amalia', 
            'lia', 'ria', 'dhea', 'aulia', 'ayu', 'intan', 'angel', 'chandra', 
            'cantika', 'lisa', 'novi', 'sarah', 'mey', 'meylani', 'selvi', 'selvia', 
            'linda', 'yani', 'ani', 'erika', 'elizabeth', 'rachel', 'clara', 'nadia', 
            'nadya', 'fani', 'fanny', 'tari', 'ndah', 'nia'
          ];

          for (var j = 0; j < femaleTriggers.length; j++) {
            if (lower.indexOf(femaleTriggers[j]) !== -1) {
              if (lower.indexOf('saputra') !== -1 || lower.indexOf('putra') !== -1 || lower.indexOf('budi') !== -1) {
                return false;
              }
              return true;
            }
          }

          if (lower.endsWith('ti') || lower.endsWith('ni') || lower.endsWith('mi') || lower.endsWith('na') || lower.endsWith('ya') || lower.endsWith('sa')) {
            var maleExceptions = ['budi', 'ari', 'andri', 'hendri', 'heri', 'feri', 'fandy', 'billy', 'rudi', 'yudi', 'dedi', 'roni', 'tony', 'joni', 'adi', 'aldi', 'hadi', 'fauzi', 'fikri', 'fahmi', 'boby', 'dani', 'deni', 'doni', 'rony', 'ali', 'reza'];
            if (maleExceptions.some(function(exp) { return lower.endsWith(exp) || lower === exp; })) {
              return false;
            }
            return true;
          }

          return false;
        }

        var toast = document.getElementById('social-proof-toast');
        var avatarImg = document.getElementById('sp-avatar');
        var nameEl = document.getElementById('sp-name');
        var messageEl = document.getElementById('sp-message');
        var timeEl = document.getElementById('sp-time');

        if (!toast || !nameEl || !messageEl || !timeEl) return;

        function getRandomItem(arr) {
          return arr[Math.floor(Math.random() * arr.length)];
        }

        // Keep track of shown names to make it look even more authentic
        var remainingNames = names.slice();
        var remainingCities = cities.slice();

        function showSocialProof() {
          if (remainingNames.length === 0) remainingNames = names.slice();
          if (remainingCities.length === 0) remainingCities = cities.slice();

          // Pick and remove
          var nameIdx = Math.floor(Math.random() * remainingNames.length);
          var name = remainingNames.splice(nameIdx, 1)[0];

          var cityIdx = Math.floor(Math.random() * remainingCities.length);
          var city = remainingCities.splice(cityIdx, 1)[0];

          var nameIsFemale = isFemale(name);
          var photoId = '';

          if (nameIsFemale) {
            if (avatarType === 'hijab') {
              photoId = getRandomItem(hijabAvatars);
            } else if (avatarType === 'cewek') {
              photoId = getRandomItem(cewekAvatars);
            } else if (avatarType === 'wa') {
              photoId = getRandomItem(cewekAvatars.concat(hijabAvatars));
            } else {
              photoId = getRandomItem(cewekAvatars);
            }
          } else {
            if (avatarType === 'wa') {
              photoId = getRandomItem(waAvatars);
            } else if (avatarType === 'hijab') {
              photoId = getRandomItem(hijabAvatars); // fallback to hijab if female name, male name fallback?
            } else {
              photoId = getRandomItem(cowokAvatars);
            }
          }
          
          // Formulate avatar URL nicely sized and squared
          if (avatarImg && photoId) {
            var avatarUrl = 'https://images.unsplash.com/' + photoId + '?auto=format&fit=crop&w=120&h=120&q=80';
            avatarImg.src = avatarUrl;
          }
          
          nameEl.innerText = name;
          messageEl.innerHTML = 'dari <strong style="color: ' + brandColor + '; font-weight:700;">' + city + '</strong> ' + statusText + ' <span style="font-weight: 700;">' + productName + '</span>';
          
          var minutesAgo = Math.floor(Math.random() * 15) + 1;
          timeEl.innerHTML = '<i class="fas fa-clock"></i> &nbsp;' + (minutesAgo === 1 ? 'Baru saja' : minutesAgo + ' menit yang lalu');

          // Trigger show with animation
          toast.style.display = 'block';
          toast.classList.remove('hide');
          toast.classList.add('show');

          // Hide after duration
          setTimeout(function() {
            toast.classList.remove('show');
            toast.classList.add('hide');
            setTimeout(function() {
              if (toast.classList.contains('hide') && !toast.classList.contains('show')) {
                toast.style.display = 'none';
              }
            }, 400);
          }, durationSec * 1000);
        }

        // Delay starting social proof popups to let user settle in
        setTimeout(function() {
          showSocialProof();
          setInterval(showSocialProof, intervalSec * 1000);
        }, 1200);
      })();
    </script>
    
    <script>
      // Disable right-click context menu
      document.addEventListener('contextmenu', function(e) {
        e.preventDefault();
      }, false);
      
      // Disable inspect element shortcut keys
      document.addEventListener('keydown', function(e) {
        if (
          e.key === 'F12' || 
          (e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'i' || e.key === 'C' || e.key === 'c' || e.key === 'J' || e.key === 'j')) ||
          (e.ctrlKey && (e.key === 'U' || e.key === 'u'))
        ) {
          e.preventDefault();
        }
      }, false);

      // Disable image dragging and selectstart events
      document.addEventListener('dragstart', function(e) {
        if (e.target.tagName === 'IMG') {
          e.preventDefault();
        }
      }, false);
      
      document.addEventListener('selectstart', function(e) {
        e.preventDefault();
      }, false);
    </script>
